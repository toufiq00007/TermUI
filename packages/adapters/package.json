{
  "name": "@termuijs/adapters",
  "homepage": "https://www.termui.io/docs/adapters/overview",
  "repository": {
    "type": "git",
    "url": "https://github.com/Karanjot786/TermUI"
  },
  "version": "0.1.6",
  "description": "Adapters for popular CLI libraries to integrate with TermUI",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@termuijs/core": "workspace:*",
    "@termuijs/widgets": "workspace:*",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "conf": "^10.2.0",
    "dotenv": "^16.0.0",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "zod": "^3.0.0",
    "execa": "^8.0.1"
  },
  "peerDependencies": {
    "@octokit/rest": "^21.0.0",
    "conf": "^10.2.0",
    "commander": "^15.0.0",
    "zod": "^3.0.0",
    "openai": "^4.0.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.0.0",
    "clipboardy": "^3.0.0",
    "dotenv": "^16.0.0",
    "simple-git": "^3.27.0",
    "keytar": "^7.9.0",
    "execa": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@octokit/rest": {
      "optional": true
    },
    "conf": {
      "optional": true
    },
    "commander": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "chalk": {
      "optional": true
    },
    "clipboardy": {
      "optional": true
    },
    "dotenv": {
      "optional": true
    },
    "simple-git": {
      "optional": true
    },
    "keytar": {
      "optional": true
    },
    "execa": {
      "optional": true
    }
  },
  "keywords": [
    "terminal",
    "tui",
    "cli",
    "adapters",
    "dotenv"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18.0.0"
  }
}
